{
  "name": "trading-sandbox-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:pages && npm run build:wiki && npm run build:static",
    "build:pages": "tsx build/build-pages.ts",
    "build:wiki": "tsx build/build-wiki.ts",
    "build:static": "tsx build/copy-static.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "npx serve dist/ -p 3000 --no-clipboard",
    "dev:wiki": "vitepress dev wiki"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "markdown-it": "^14.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitepress": "^1.5.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
